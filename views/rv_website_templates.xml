<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Reusable Services & Amenities block (expects `services`)
         ============================================================ -->
    <template id="rv_services_block" name="RV Services &amp; Amenities Block">
        <t t-if="services">
            <div class="card shadow-sm mb-4 rv-services-card">
                <div class="card-body">
                    <h5 class="card-title text-muted mb-3">
                        <i class="fa fa-plug me-2" title="Services"/>
                        Services &amp; Amenities
                    </h5>
                    <div class="row">
                        <t t-foreach="services" t-as="svc">
                            <div class="col-md-6 mb-2">
                                <i t-attf-class="fa #{svc.icon or 'fa-check'} fa-fw me-2 text-success" title="Service"/>
                                <strong><t t-esc="svc.name"/></strong>
                                <t t-if="svc.detail">
                                    <span class="text-muted"> — <t t-esc="svc.detail"/></span>
                                </t>
                                <t t-if="svc.availability == 'onsite'">
                                    <span class="badge bg-success ms-2">On-site</span>
                                </t>
                                <t t-if="svc.availability == 'nearby'">
                                    <span class="badge bg-info text-dark ms-2">Nearby</span>
                                    <div class="small text-muted ms-4">
                                        <t t-if="svc.location_name">
                                            <t t-esc="svc.location_name"/><t t-if="svc.location_address">, </t>
                                        </t>
                                        <t t-if="svc.location_address">
                                            <t t-esc="svc.location_address"/>
                                        </t>
                                        <t t-if="svc.map_query">
                                            <a t-attf-href="https://www.google.com/maps/dir/?api=1&amp;destination=#{svc.map_query}"
                                               target="_blank" rel="noopener" class="ms-1">
                                                <i class="fa fa-map-marker me-1" title="Map"/>directions
                                            </a>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Availability Page — public calendar + occupancy counter
         ============================================================ -->
    <template id="rv_availability_page" name="RV Parking Availability">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-4">

                    <!-- Header -->
                    <div class="text-center mb-4">
                        <t t-if="settings and settings.logo_primary">
                            <img t-att-src="image_data_uri(settings.logo_primary)"
                                 style="max-height: 60px;" alt="Elks" class="mb-2"/>
                        </t>
                        <h1 class="text-primary">
                            <t t-esc="lodge_name"/>
                            <t t-if="lodge_number"> #<t t-esc="lodge_number"/></t>
                        </h1>
                        <h2 class="text-muted">RV Parking Availability</h2>
                        <p class="lead">
                            Suggested donation:
                            <strong class="text-success">
                                $<t t-esc="'%.2f' % nightly_rate"/>
                            </strong> per night
                        </p>
                    </div>

                    <!-- Occupancy Counter Widget -->
                    <div class="row mb-4 justify-content-center">
                        <div class="col-md-4 col-sm-6 mb-3">
                            <div class="card text-center shadow-sm border-success">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-muted">
                                        Spaces Available Today
                                    </h6>
                                    <h1 class="display-3 mb-0">
                                        <t t-if="spaces_available > 0">
                                            <span class="text-success">
                                                <t t-esc="spaces_available"/>
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span class="text-danger">FULL</span>
                                        </t>
                                    </h1>
                                    <p class="text-muted mb-0">
                                        of <t t-esc="total_spaces"/> total spaces
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-6 mb-3">
                            <div class="card text-center shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-subtitle mb-2 text-muted">
                                        Currently Occupied
                                    </h6>
                                    <h1 class="display-3 mb-0">
                                        <span class="text-primary">
                                            <t t-esc="current_occupancy"/>
                                        </span>
                                    </h1>
                                    <p class="text-muted mb-0">
                                        registered guests
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Month Navigation -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <a t-attf-href="/rv-parking?month=#{prev_month}&amp;year=#{prev_year}"
                           class="btn btn-outline-secondary">
                            <i class="fa fa-chevron-left" title="Previous"/> Previous
                        </a>
                        <h3 class="mb-0">
                            <t t-esc="month_name"/> <t t-esc="year"/>
                        </h3>
                        <a t-attf-href="/rv-parking?month=#{next_month}&amp;year=#{next_year}"
                           class="btn btn-outline-secondary">
                            Next <i class="fa fa-chevron-right" title="Next"/>
                        </a>
                    </div>

                    <!-- Calendar Grid -->
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered text-center">
                            <thead class="table-dark">
                                <tr>
                                    <th>Sun</th><th>Mon</th><th>Tue</th>
                                    <th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="weeks" t-as="week">
                                    <tr>
                                        <t t-foreach="week" t-as="day">
                                            <t t-if="day.get('in_month')">
                                                <td t-attf-class="#{day.get('full') and 'table-danger' or (day.get('available', 0) &lt;= warning_threshold and 'table-warning' or 'table-success')}"
                                                    style="height: 70px; vertical-align: top; padding: 6px;">
                                                    <div class="fw-bold">
                                                        <t t-esc="day.get('day')"/>
                                                    </div>
                                                    <small>
                                                        <t t-if="day.get('full')">
                                                            <span class="text-danger fw-bold">FULL</span>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-success">
                                                                <t t-esc="day.get('available')"/> open
                                                            </span>
                                                        </t>
                                                    </small>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td style="height: 70px; background: #f8f9fa;"/>
                                            </t>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <!-- Legend -->
                    <div class="d-flex justify-content-center gap-4 mb-4">
                        <span>
                            <span class="badge bg-success">&amp;nbsp;&amp;nbsp;</span>
                            Available
                        </span>
                        <span>
                            <span class="badge bg-warning text-dark">&amp;nbsp;&amp;nbsp;</span>
                            Limited (<t t-esc="warning_threshold"/> or fewer)
                        </span>
                        <span>
                            <span class="badge bg-danger">&amp;nbsp;&amp;nbsp;</span>
                            Full
                        </span>
                    </div>

                    <!-- Services & Amenities -->
                    <t t-call="elksrvparking.rv_services_block"/>

                    <!-- Reserve Button -->
                    <div class="text-center mb-5">
                        <a href="/rv-parking/request"
                           class="btn btn-primary btn-lg px-5">
                            <i class="fa fa-calendar-plus-o me-2" title="Add Date"/>
                            Request a Reservation
                        </a>
                    </div>

                    <!-- Footer note -->
                    <p class="text-center text-muted small">
                        RV parking is first-come, first-served. Reservations are
                        requests only and must be confirmed by lodge staff.
                        All donations support
                        <t t-esc="lodge_name"/>
                        <t t-if="lodge_number"> #<t t-esc="lodge_number"/></t>.
                    </p>

                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Reservation Request Form
         ============================================================ -->
    <template id="rv_request_page" name="RV Reservation Request">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-4" style="max-width: 700px;">

                    <div class="text-center mb-4">
                        <h2 class="text-primary">
                            <i class="fa fa-calendar-plus-o me-2" title="Add Date"/>
                            RV Parking Reservation Request
                        </h2>
                        <p class="text-muted">
                            <t t-esc="lodge_name"/>
                            <t t-if="lodge_number"> #<t t-esc="lodge_number"/></t>
                            — Suggested donation:
                            <strong class="text-success">
                                $<t t-esc="'%.2f' % nightly_rate"/>
                            </strong> / night
                        </p>
                    </div>

                    <!-- Error alert for availability / validation -->
                    <t t-if="error">
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fa fa-exclamation-triangle me-2" title="Warning"/>
                            <t t-esc="error"/>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"/>
                        </div>
                    </t>

                    <!-- Services & Amenities -->
                    <t t-call="elksrvparking.rv_services_block"/>

                    <div class="card shadow-sm">
                        <div class="card-body">
                            <form action="/rv-parking/request" method="post"
                                  class="needs-validation">
                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <h5 class="mb-3 text-muted">Guest Information</h5>

                                <div class="mb-3">
                                    <label for="guest_name" class="form-label">
                                        Your Name <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" name="guest_name" id="guest_name"
                                           class="form-control" required=""
                                           t-att-value="guest_name if guest_name else ''"
                                           placeholder="Full name"/>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="member_number" class="form-label">
                                            Elks Member # <span class="text-danger">*</span>
                                        </label>
                                        <input type="text" name="member_number"
                                               id="member_number" class="form-control"
                                               pattern="[0-9]*" inputmode="numeric"
                                               title="Numbers only" required="required"
                                               t-att-value="member_number if member_number else ''"
                                               placeholder="e.g. 654321"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="contact_phone" class="form-label">
                                            Contact Phone
                                        </label>
                                        <input type="tel" name="contact_phone"
                                               id="contact_phone" class="form-control"
                                               t-att-value="contact_phone if contact_phone else ''"
                                               placeholder="(555) 123-4567"/>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label for="home_lodge_number" class="form-label">
                                            Home Lodge #
                                        </label>
                                        <input type="text" name="home_lodge_number"
                                               id="home_lodge_number" class="form-control"
                                               pattern="[0-9]*" inputmode="numeric"
                                               title="Numbers only"
                                               t-att-value="home_lodge_number if home_lodge_number else ''"
                                               placeholder="e.g. 896"/>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="home_lodge_name" class="form-label">
                                            Home Lodge Name
                                        </label>
                                        <input type="text" name="home_lodge_name"
                                               id="home_lodge_name" class="form-control"
                                               t-att-value="home_lodge_name if home_lodge_name else ''"
                                               placeholder="e.g. Lewiston"/>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="home_lodge_state" class="form-label">
                                            Home Lodge State
                                        </label>
                                        <select name="home_lodge_state" id="home_lodge_state"
                                                class="form-select">
                                            <option value="">-- Select --</option>
                                            <option value="AL">Alabama</option>
                                            <option value="AK">Alaska</option>
                                            <option value="AZ">Arizona</option>
                                            <option value="AR">Arkansas</option>
                                            <option value="CA">California</option>
                                            <option value="CO">Colorado</option>
                                            <option value="CT">Connecticut</option>
                                            <option value="DE">Delaware</option>
                                            <option value="FL">Florida</option>
                                            <option value="GA">Georgia</option>
                                            <option value="HI">Hawaii</option>
                                            <option value="ID">Idaho</option>
                                            <option value="IL">Illinois</option>
                                            <option value="IN">Indiana</option>
                                            <option value="IA">Iowa</option>
                                            <option value="KS">Kansas</option>
                                            <option value="KY">Kentucky</option>
                                            <option value="LA">Louisiana</option>
                                            <option value="ME">Maine</option>
                                            <option value="MD">Maryland</option>
                                            <option value="MA">Massachusetts</option>
                                            <option value="MI">Michigan</option>
                                            <option value="MN">Minnesota</option>
                                            <option value="MS">Mississippi</option>
                                            <option value="MO">Missouri</option>
                                            <option value="MT">Montana</option>
                                            <option value="NE">Nebraska</option>
                                            <option value="NV">Nevada</option>
                                            <option value="NH">New Hampshire</option>
                                            <option value="NJ">New Jersey</option>
                                            <option value="NM">New Mexico</option>
                                            <option value="NY">New York</option>
                                            <option value="NC">North Carolina</option>
                                            <option value="ND">North Dakota</option>
                                            <option value="OH">Ohio</option>
                                            <option value="OK">Oklahoma</option>
                                            <option value="OR">Oregon</option>
                                            <option value="PA">Pennsylvania</option>
                                            <option value="RI">Rhode Island</option>
                                            <option value="SC">South Carolina</option>
                                            <option value="SD">South Dakota</option>
                                            <option value="TN">Tennessee</option>
                                            <option value="TX">Texas</option>
                                            <option value="UT">Utah</option>
                                            <option value="VT">Vermont</option>
                                            <option value="VA">Virginia</option>
                                            <option value="WA">Washington</option>
                                            <option value="WV">West Virginia</option>
                                            <option value="WI">Wisconsin</option>
                                            <option value="WY">Wyoming</option>
                                            <option value="DC">District of Columbia</option>
                                            <option value="PR">Puerto Rico</option>
                                            <option value="GU">Guam</option>
                                            <option value="VI">U.S. Virgin Islands</option>
                                        </select>
                                    </div>
                                </div>

                                <hr class="my-3"/>
                                <h5 class="mb-3 text-muted">Stay Details</h5>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="check_in" class="form-label">
                                            Check-In Date <span class="text-danger">*</span>
                                        </label>
                                        <input type="date" name="check_in" id="check_in"
                                               class="form-control" required=""
                                               t-att-value="check_in"
                                               t-att-min="today"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="nights" class="form-label">
                                            Number of Nights <span class="text-danger">*</span>
                                        </label>
                                        <input type="number" name="nights" id="nights"
                                               class="form-control" required=""
                                               t-att-value="nights" min="1"
                                               t-att-max="max_nights"/>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="num_occupants" class="form-label">
                                            Number of People <span class="text-danger">*</span>
                                        </label>
                                        <input type="number" name="num_occupants" id="num_occupants"
                                               class="form-control" required="required" min="1"
                                               t-att-value="num_occupants"
                                               placeholder="e.g. 2"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="num_pets" class="form-label">
                                            Number of Pets <span class="text-danger">*</span>
                                        </label>
                                        <input type="number" name="num_pets" id="num_pets"
                                               class="form-control" required="required" min="0"
                                               t-att-value="num_pets"
                                               placeholder="0 if none"/>
                                    </div>
                                </div>

                                <!-- Live availability check area -->
                                <div id="availability_result" class="mb-3"/>

                                <div class="d-grid gap-2 mt-3">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fa fa-paper-plane me-2" title="Submit"/>
                                        Submit Reservation Request
                                    </button>
                                </div>

                                <p class="text-muted small mt-3 text-center">
                                    This is a request only. Lodge staff will confirm
                                    your reservation. Payment is collected on arrival.
                                    Maximum stay is <strong><t t-esc="max_nights"/></strong> nights.
                                </p>
                            </form>
                        </div>
                    </div>

                    <div class="text-center mt-3">
                        <a href="/rv-parking" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1" title="Back"/>
                            Back to Availability Calendar
                        </a>
                    </div>

                </div>
            </div>

            <!-- Phone number auto-formatting + restore state selection -->
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    // Phone auto-format
                    var phone = document.getElementById('contact_phone');
                    if (phone) {
                        phone.addEventListener('input', function () {
                            var digits = this.value.replace(/\D/g, '');
                            if (digits.length === 0) { this.value = ''; return; }
                            if (digits.length &lt;= 3) {
                                this.value = '(' + digits;
                            } else if (digits.length &lt;= 6) {
                                this.value = '(' + digits.slice(0,3) + ') ' + digits.slice(3);
                            } else {
                                this.value = '(' + digits.slice(0,3) + ') ' + digits.slice(3,6) + '-' + digits.slice(6,10);
                            }
                        });
                    }
                    // Restore state dropdown on validation error re-render
                    var stateVal = '<t t-esc="home_lodge_state or ''"/>';
                    if (stateVal) {
                        var sel = document.getElementById('home_lodge_state');
                        if (sel) sel.value = stateVal;
                    }
                });
            </script>
        </t>
    </template>

    <!-- ============================================================
         Confirmation / Thank-you page
         ============================================================ -->
    <template id="rv_request_thanks" name="RV Reservation Submitted">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5 text-center" style="max-width: 600px;">

                    <div class="mb-4">
                        <i class="fa fa-check-circle text-success" style="font-size: 64px;" title="Done"/>
                    </div>

                    <h2 class="text-primary mb-3">Reservation Request Submitted!</h2>

                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <p class="mb-1">
                                <strong>Confirmation #:</strong>
                                <span class="text-success fw-bold">
                                    <t t-esc="reg.name"/>
                                </span>
                            </p>
                            <p class="mb-1">
                                <strong>Guest:</strong>
                                <t t-esc="reg.guest_name"/>
                            </p>
                            <p class="mb-1">
                                <strong>Check-In:</strong>
                                <t t-esc="reg.check_in"/>
                            </p>
                            <p class="mb-0">
                                <strong>Nights:</strong>
                                <t t-esc="reg.nights"/>
                            </p>
                        </div>
                    </div>

                    <p class="text-muted">
                        Thank you for your interest in visiting
                        <strong><t t-esc="lodge_name"/></strong>!
                        Lodge staff will review your request and contact you
                        to confirm your reservation. Payment is collected on arrival.
                    </p>

                    <!-- Special note info bubble -->
                    <t t-if="rv_slip_note">
                        <div class="alert alert-info text-start mt-4" role="alert"
                             style="max-width: 560px; margin: 0 auto;">
                            <i class="fa fa-info-circle me-2" title="Info"/>
                            <strong>Note from the Lodge:</strong>
                            <div class="mt-1" style="white-space: pre-line;">
                                <t t-esc="rv_slip_note"/>
                            </div>
                        </div>
                    </t>

                    <!-- Services & Amenities -->
                    <div class="text-start mt-4">
                        <t t-call="elksrvparking.rv_services_block"/>
                    </div>

                    <!-- Google Map -->
                    <t t-if="map_query">
                        <div class="mt-4 mb-3">
                            <h5 class="text-muted mb-2">
                                <i class="fa fa-map-marker me-1" title="Location"/>
                                Find Us
                            </h5>
                            <p class="text-muted small mb-2">
                                <t t-esc="map_address"/>
                            </p>
                            <div class="ratio ratio-16x9" style="max-width: 560px; margin: 0 auto;">
                                <iframe
                                    t-attf-src="https://www.google.com/maps?q=#{map_query}&amp;output=embed"
                                    style="border: 0; border-radius: 8px;"
                                    allowfullscreen=""
                                    loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"/>
                            </div>
                        </div>
                    </t>

                    <div class="d-flex justify-content-center gap-3 mt-3">
                        <a t-attf-href="/rv-parking/receipt/#{reg.id}"
                           class="btn btn-success" target="_blank">
                            <i class="fa fa-print me-1" title="Print"/>
                            Print Registration Slip
                        </a>
                        <a href="/rv-parking" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-1" title="Back"/>
                            Back to Availability
                        </a>
                    </div>

                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Printable Guest Registration Slip (public, no Odoo chrome)
         ============================================================ -->
    <template id="rv_guest_receipt_page" name="RV Guest Registration Slip">
        <t t-call="website.layout">
            <!-- Print CSS: hide all website chrome, fit to one page -->
            <style>
                @media print {
                    header, footer, nav, .o_main_navbar,
                    #top, #bottom, .o_footer, .o_header,
                    .d-print-none, .rv-map-section { display: none !important; }
                    #wrap { padding: 0 !important; margin: 0 !important; }
                    .rv-slip-container { max-width: 100% !important; padding: 0 !important; }
                    .rv-slip-border { border: none !important; padding: 8px !important; }
                    .rv-slip-border h2 { font-size: 20px !important; }
                    .rv-slip-border h4 { font-size: 14px !important; margin: 2px 0 8px 0 !important; }
                    .rv-slip-border td { padding: 5px 10px !important; font-size: 12px !important; }
                    .rv-slip-logo { max-height: 40px !important; }
                    .rv-slip-note { padding: 6px 10px !important; margin-bottom: 8px !important; }
                    body { margin: 0; }
                }
            </style>

            <div id="wrap" class="oe_structure">
                <div class="container py-4 rv-slip-container" style="max-width: 650px;">

                    <!-- Print button (hidden on print) -->
                    <div class="text-center mb-4 d-print-none">
                        <button class="btn btn-primary btn-lg" onclick="window.print()">
                            <i class="fa fa-print me-2" title="Print"/>
                            Print Registration Slip
                        </button>
                    </div>

                    <!-- Receipt content -->
                    <div class="rv-slip-border"
                         style="border: 2px solid #333; padding: 24px; font-family: Arial, sans-serif;">

                        <!-- Header with logo -->
                        <div class="text-center mb-3">
                            <t t-if="settings and settings.logo_primary">
                                <img t-att-src="image_data_uri(settings.logo_primary)"
                                     class="rv-slip-logo" style="max-height: 50px;" alt="Elks USA"/>
                            </t>
                        </div>
                        <h2 class="text-center" style="margin: 0 0 2px 0; color: #333;">
                            <t t-esc="lodge_name"/>
                            <t t-if="lodge_number"> #<t t-esc="lodge_number"/></t>
                        </h2>
                        <p class="text-center" style="font-size: 11px; color: #777; margin: 0 0 2px 0;">
                            Benevolent and Protective Order of Elks
                        </p>
                        <!-- Lodge address -->
                        <t t-if="lodge_address">
                            <p class="text-center" style="font-size: 11px; color: #555; margin: 0 0 4px 0;">
                                <t t-esc="lodge_address"/>
                            </p>
                        </t>
                        <t t-if="lodge_phone">
                            <p class="text-center" style="font-size: 11px; color: #555; margin: 0 0 4px 0;">
                                <t t-esc="lodge_phone"/>
                            </p>
                        </t>
                        <h4 class="text-center" style="color: #2e7d32; margin: 4px 0 12px 0;">
                            RV Parking — Guest Registration Slip
                        </h4>

                        <hr style="border-top: 2px solid #2e7d32; margin: 0 0 16px 0;"/>

                        <!-- Registration details table -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;">
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; width: 35%; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Confirmation #
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-size: 14px; font-weight: bold; color: #2e7d32;">
                                    <t t-esc="reg.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Guest Name
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.guest_name"/>
                                </td>
                            </tr>
                            <tr t-if="reg.member_number">
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Member #
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.member_number"/>
                                </td>
                            </tr>
                            <tr t-if="reg.home_lodge_number or reg.home_lodge_name">
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Home Lodge
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-if="reg.home_lodge_number">#<t t-esc="reg.home_lodge_number"/> </t>
                                    <t t-esc="reg.home_lodge_name or ''"/>
                                    <t t-if="reg.home_lodge_state">
                                        (<t t-esc="reg.home_lodge_state"/>)
                                    </t>
                                </td>
                            </tr>
                            <tr t-if="reg.contact_phone">
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Contact Phone
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.contact_phone"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Check-In
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.check_in"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Check-Out
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.check_out or 'TBD'"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Nights
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px;">
                                    <t t-esc="reg.nights"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold; font-size: 13px; background: #f5f5f5;">
                                    Estimated Donation
                                </td>
                                <td style="border: 1px solid #aaa; padding: 8px 12px; font-weight: bold;">
                                    $<t t-esc="'%.2f' % reg.total_amount"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Services & Amenities (print-friendly) -->
                        <t t-if="services">
                            <div style="border: 1px solid #ccc; border-radius: 6px; padding: 8px 12px; margin-bottom: 12px;">
                                <div style="font-size: 12px; font-weight: bold; color: #2e7d32; margin-bottom: 4px;">
                                    Services &amp; Amenities
                                </div>
                                <t t-foreach="services" t-as="svc">
                                    <div style="font-size: 12px; color: #333; margin: 2px 0;">
                                        <t t-esc="svc.name"/>
                                        <t t-if="svc.detail"> (<t t-esc="svc.detail"/>)</t>
                                        <t t-if="svc.availability == 'onsite'">
                                            — On-site
                                        </t>
                                        <t t-if="svc.availability == 'nearby'">
                                            — Nearby:
                                            <t t-if="svc.location_name"><t t-esc="svc.location_name"/>, </t>
                                            <t t-esc="svc.location_address or ''"/>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- Special note info bubble -->
                        <t t-if="rv_slip_note">
                            <div class="rv-slip-note" style="background: #e8f4fd; border: 1px solid #b8daff; border-radius: 6px; padding: 10px 14px; margin-bottom: 12px;">
                                <div style="font-size: 12px; font-weight: bold; color: #004085; margin-bottom: 4px;">
                                    <i class="fa fa-info-circle me-1" title="Info"/> Note from the Lodge
                                </div>
                                <div style="font-size: 12px; color: #004085; white-space: pre-line;">
                                    <t t-esc="rv_slip_note"/>
                                </div>
                            </div>
                        </t>

                        <p style="font-size: 11px; color: #777; text-align: center; margin-bottom: 8px;">
                            This is a reservation request. Lodge staff will confirm your reservation
                            and contact you. Payment is collected on arrival.
                        </p>
                        <p style="font-size: 10px; color: #aaa; text-align: center; margin: 0;">
                            Thank you for visiting
                            <t t-esc="lodge_name"/>
                            <t t-if="lodge_number"> #<t t-esc="lodge_number"/></t>!
                        </p>
                    </div>

                    <!-- Printable map section: static image + QR code -->
                    <t t-if="map_query">
                        <div class="text-center mt-3">
                            <h6 class="text-muted mb-2">
                                <i class="fa fa-map-marker me-1" title="Location"/>
                                <t t-esc="map_address"/>
                            </h6>

                            <!-- QR code — links to Google Maps directions (prints well) -->
                            <t t-if="qr_url">
                                <div style="margin: 8px auto; max-width: 180px;">
                                    <img t-att-src="qr_url"
                                         alt="Scan for directions"
                                         style="width: 150px; height: 150px;"/>
                                    <p style="font-size: 10px; color: #777; margin: 4px 0 0 0;">
                                        Scan for driving directions
                                    </p>
                                </div>
                            </t>

                            <!-- Interactive map for on-screen viewing (hidden when printing) -->
                            <div class="d-print-none" style="max-width: 650px; margin: 8px auto 0 auto;">
                                <div class="ratio ratio-16x9">
                                    <iframe
                                        t-attf-src="https://www.google.com/maps?q=#{map_query}&amp;output=embed"
                                        style="border: 0; border-radius: 8px;"
                                        allowfullscreen=""
                                        loading="lazy"
                                        referrerpolicy="no-referrer-when-downgrade"/>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- Back link (hidden on print) -->
                    <div class="text-center mt-3 d-print-none">
                        <a href="/rv-parking" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left me-1" title="Back"/>
                            Back to Availability
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
