<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Auto check-out guests at scheduled end of stay (daily at 3 PM) -->
        <record id="ir_cron_rv_auto_checkout" model="ir.cron">
            <field name="name">RV Park: Auto Check-Out</field>
            <field name="model_id" ref="model_elks_rv_registration"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_checkout()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
