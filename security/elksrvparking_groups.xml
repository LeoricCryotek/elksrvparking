<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- Privilege category (Odoo 19 style) -->
    <record id="privilege_elksrvparking" model="res.groups.privilege">
        <field name="name">RV Parking</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="sequence">70</field>
    </record>

    <!-- User group -->
    <record id="group_elksrvparking_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_elksrvparking"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager group -->
    <record id="group_elksrvparking_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_elksrvparking"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('elksrvparking.group_elksrvparking_user'))]"/>
    </record>

    </data>

    <!-- Always assign admin — outside noupdate so it runs on upgrade too -->
    <data noupdate="0">
        <record id="group_elksrvparking_manager" model="res.groups">
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
